# ── Whitepaper Translator — server environment ───────────────────────
# Set in Vercel project settings. Never expose to the frontend or commit real values.

# Anthropic API key (server-side only; read by the Anthropic SDK in api/chat.js).
ANTHROPIC_API_KEY=

# CORS: comma-separated list of origins allowed to call /api/chat from a browser.
# Defaults to the production domain + localhost dev ports if unset.
CORS_ALLOWLIST=https://translator.giovannieverduin.com

# Rate limit on /api/chat (per IP). Defaults: 20 requests per 10 minutes.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=600000

# Durable rate limiting (Redis). When set, the limit is global across all
# serverless instances and survives cold starts. Set automatically by the Vercel
# Redis marketplace integration (connection string). If unset, the limiter falls
# back to best-effort in-memory (per instance). KV_URL is accepted as a fallback.
REDIS_URL=
